#include <tunables/global>

/usr/local/bin/shushunya-agent-shell {
  # Template profile for the host launcher. Install with
  # scripts/setup-apparmor.sh after reviewing local paths.

  #include <abstractions/base>
  #include <abstractions/bash>

  capability setgid,
  capability setuid,

  /usr/local/bin/shushunya-agent-shell rix,
  /usr/bin/bash rix,
  /usr/bin/sudo rix,
  /usr/bin/sg rix,
  /usr/bin/bwrap rix,
  /usr/bin/python3 rix,
  /usr/bin/env rix,

  /etc/group r,
  /etc/passwd r,
  /etc/sudoers r,
  /etc/sudoers.d/** r,

  /media/shushunya/ARCHIVE/shushunya-agent-sandbox/** r,
  /media/shushunya/ARCHIVE/shushunya-agent-sandbox/profile/run-in-sandbox.sh rix,

  deny /home/** rwklx,
  deny /root/** rwklx,
  deny /media/shushunya/SHUSHUNYA/** rwklx,

  /tmp/** rw,
  /run/** rw,
  /dev/null rw,
  /dev/urandom r,
  /dev/random r,
}
