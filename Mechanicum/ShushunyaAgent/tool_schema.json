{
  "version": 1,
  "response_contract": "exactly_one_json_object_per_step",
  "actions": {
    "final": {
      "required": ["action", "message"],
      "properties": {
        "action": "final",
        "message": "string"
      }
    },
    "sandbox_status": {
      "required": ["action"],
      "properties": {
        "action": "sandbox_status"
      }
    },
    "archive_status": {
      "required": ["action"],
      "properties": {
        "action": "archive_status"
      }
    },
    "archive_memory_events": {
      "required": ["action"],
      "properties": {
        "action": "archive_memory_events",
        "limit": "integer",
        "component": ["librarian", "memory_gateway"],
        "event_action": "string",
        "requester": "string"
      }
    },
    "archive_memory_gateway": {
      "required": ["action"],
      "properties": {
        "action": "archive_memory_gateway"
      }
    },
    "archive_search": {
      "required": ["action", "kind", "query"],
      "properties": {
        "action": "archive_search",
        "kind": ["focus", "vector", "graph"],
        "query": "string"
      }
    },
    "archive_memory_catalog": {
      "required": ["action"],
      "properties": {
        "action": "archive_memory_catalog"
      }
    },
    "archive_memory_search": {
      "required": ["action", "query"],
      "properties": {
        "action": "archive_memory_search",
        "query": "string",
        "limit": "integer",
        "layers": "comma string or string array: focus,wiki,vector,graph",
        "include_content": "boolean"
      }
    },
    "archive_memory_read": {
      "required": ["action", "kind"],
      "properties": {
        "action": "archive_memory_read",
        "kind": ["focus", "wiki"],
        "id": "string",
        "title": "string",
        "max_chars": "integer"
      }
    },
    "archive_memory_propose": {
      "required": ["action", "proposal"],
      "properties": {
        "action": "archive_memory_propose",
        "target": ["auto", "focus", "wiki", "vector", "graph"],
        "importance": "integer 1..5",
        "proposal": "string",
        "evidence": "string"
      }
    },
    "shell": {
      "required": ["action", "cmd"],
      "properties": {
        "action": "shell",
        "cmd": "string",
        "timeout": "integer",
        "reason": "string"
      }
    },
    "python": {
      "required": ["action", "code"],
      "properties": {
        "action": "python",
        "code": "string",
        "timeout": "integer"
      }
    },
    "web_search": {
      "required": ["action", "query"],
      "properties": {
        "action": "web_search",
        "query": "string",
        "limit": "integer"
      }
    },
    "web_fetch": {
      "required": ["action", "url"],
      "properties": {
        "action": "web_fetch",
        "url": "public_http_url",
        "max_bytes": "integer",
        "returns": "text/title/encoding for textual responses; is_binary and bytes_read without decoded text for binary responses"
      }
    },
    "list_files": {
      "required": ["action", "path"],
      "properties": {
        "action": "list_files",
        "path": "sandbox_path",
        "max_depth": "integer",
        "limit": "integer",
        "offset": "integer",
        "returns": "items plus total_count, offset, limit, next_offset, truncated"
      }
    },
    "read_file": {
      "required": ["action", "path"],
      "properties": {
        "action": "read_file",
        "path": "sandbox_path",
        "max_bytes": "integer",
        "offset": "integer",
        "returns": "content plus size, offset, next_offset, truncated, is_binary, encoding"
      }
    },
    "write_file": {
      "required": ["action", "path", "content"],
      "properties": {
        "action": "write_file",
        "path": "sandbox_path",
        "content": "string"
      }
    },
    "append_file": {
      "required": ["action", "path", "content"],
      "properties": {
        "action": "append_file",
        "path": "sandbox_path",
        "content": "string"
      }
    },
    "replace_in_file": {
      "required": ["action", "path", "old", "new"],
      "properties": {
        "action": "replace_in_file",
        "path": "sandbox_path",
        "old": "string",
        "new": "string",
        "count": "integer"
      }
    },
    "mkdir": {
      "required": ["action", "path"],
      "properties": {
        "action": "mkdir",
        "path": "sandbox_path"
      }
    },
    "remove_file": {
      "required": ["action", "path"],
      "properties": {
        "action": "remove_file",
        "path": "sandbox_path",
        "recursive": "boolean"
      }
    },
    "file_info": {
      "required": ["action", "path"],
      "properties": {
        "action": "file_info",
        "path": "sandbox_path",
        "sha256": "boolean",
        "max_hash_bytes": "integer"
      }
    },
    "find_files": {
      "required": ["action", "path", "pattern"],
      "properties": {
        "action": "find_files",
        "path": "sandbox_path",
        "pattern": "glob",
        "max_depth": "integer",
        "limit": "integer",
        "offset": "integer",
        "returns": "items plus total_count, offset, limit, next_offset, truncated"
      }
    },
    "search_text": {
      "required": ["action", "path", "query"],
      "properties": {
        "action": "search_text",
        "path": "sandbox_path",
        "query": "string",
        "case_sensitive": "boolean",
        "max_matches": "integer",
        "max_bytes_per_file": "integer"
      }
    }
  },
  "sandbox_path_roots": ["/work", "/sandbox-tmp", "/artifacts", "/state", "/logs", "/models", "/tools", "/home/agent"],
  "memory_policy": {
    "automatic_injection_default": true,
    "archive_internal_steps_default": true,
    "memory_namespace_default": "agent",
    "focus_limit_per_namespace": 10,
    "explicit_memory_tool": "archive_search",
    "explicit_memory_tools": ["archive_memory_gateway", "archive_memory_catalog", "archive_memory_search", "archive_memory_read", "archive_memory_propose", "archive_memory_events", "archive_search"],
    "gateway_tools": ["archive_memory_gateway", "archive_memory_catalog", "archive_memory_search", "archive_memory_read", "archive_memory_propose", "archive_memory_events"],
    "gateway_write_policy": "Agents can propose memory changes only through ArchiveOfHeresy; the librarian decides how to apply them.",
    "warning": "Archive memory is reference context only and may be stale. Agent focus/wiki/vector/graph memory is isolated from the default chat memory namespace."
  },
  "storage_policy": {
    "limit_bytes": 536870912000,
    "limit_human": "500G",
    "mode": "soft",
    "structured_file_write_enforced": true,
    "hard_quota_required_for_shell_and_python": true
  },
  "supervisor_policy": {
    "shell_enabled_default": true,
    "http_shell_enabled_default": false,
    "http_shell_requires_api_key_or_env_override": true,
    "http_shell_override_env": "SHUSHUNYA_AGENT_HTTP_ALLOW_SHELL_WITHOUT_API_KEY",
    "shell_can_be_disabled": true,
    "http_payload_field": "shell_enabled",
    "http_debug_stderr_field": "include_stderr",
    "http_steps_field": "include_steps",
    "http_max_runtime_sec_field": "max_runtime_sec",
    "http_max_tokens_field": "max_tokens",
    "http_llm_retries_field": "llm_retries",
    "http_memory_namespace_field": "memory_namespace",
    "http_task_id_field": "task_id",
    "http_resume_task_id_field": "resume_task_id",
    "http_task_journal_endpoint": "GET /task-journal?task_id=<id>&limit=80",
    "http_state_endpoint": "GET /state",
    "http_cancel_endpoint": "POST /cancel",
    "http_cancel_policy": "cooperative cancellation checked between agent steps; in-flight model/tool calls may finish first",
    "http_wait_for_slot_field": "wait_for_slot",
    "http_busy_status": "409 when wait_for_slot=false and another run is active or queued",
    "stream_duration_field": "duration_sec on tool_result and final events",
    "stream_heartbeat_event": "heartbeat",
    "stream_heartbeat_env": "SHUSHUNYA_AGENT_STREAM_HEARTBEAT_SEC",
    "default_stream_heartbeat_sec": 15,
    "http_max_request_bytes_env": "SHUSHUNYA_AGENT_MAX_REQUEST_BYTES",
    "http_llm_retries_env": "SHUSHUNYA_AGENT_LLM_RETRIES",
    "http_max_runtime_sec_env": "SHUSHUNYA_AGENT_MAX_RUNTIME_SEC",
    "default_max_request_bytes": 1048576,
    "default_llm_retries": 3,
    "default_max_runtime_sec": 1800,
    "resume_context": "recent journal events are compacted before being appended to the model prompt",
    "http_inject_memory_field": "inject_memory",
    "http_archive_internal_steps_field": "archive_internal_steps",
    "http_archive_task_field": "archive_task",
    "http_task_memory_field": "task_memory",
    "default_max_model_tokens": 1024
  },
  "web_policy": {
    "tools": ["web_search", "web_fetch"],
    "search_provider_chain": ["searxng", "marginalia_public", "wikipedia_opensearch", "brave_api"],
    "optional_env": [
      "SHUSHUNYA_AGENT_SEARXNG_URL",
      "SHUSHUNYA_AGENT_SEARCH_PROVIDERS",
      "SHUSHUNYA_AGENT_BRAVE_SEARCH_API_KEY"
    ],
    "default_search_providers": "searxng,marginalia,wikipedia,brave",
    "brave_policy": "optional fallback; not called unless brave is present in SHUSHUNYA_AGENT_SEARCH_PROVIDERS",
    "allowed_schemes": ["http", "https"],
    "blocked_targets": ["localhost", "private_ip", "loopback", "link_local", "multicast", "reserved", "unspecified"],
    "default_max_bytes": 200000
  }
}
