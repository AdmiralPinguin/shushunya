{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia Planning Packet",
  "type": "object",
  "required": [
    "ok",
    "contract_version",
    "worker",
    "kind",
    "task",
    "roles_completed",
    "problem_statement",
    "task_triage",
    "repo_survey_request",
    "dependency_map",
    "work_breakdown",
    "impact_analysis",
    "execution_forecast",
    "design_options",
    "verification_strategy",
    "surface_verification_matrix",
    "risk_register",
    "quality_bar",
    "acceptance_contract",
    "implementation_brief_blueprint",
    "implementation_work_packages",
    "planning_review_gate",
    "code_brigade_handoff",
    "next_action"
  ],
  "properties": {
    "ok": {"type": "boolean"},
    "contract_version": {"const": "eye-mechanicum.v1"},
    "worker": {"const": "PlanningBrigade"},
    "kind": {"const": "ceraxia_planning_packet"},
    "task": {"type": "string"},
    "roles_completed": {
      "type": "array",
      "prefixItems": [
        {"const": "TaskTriage"},
        {"const": "RepoSurveyor"},
        {"const": "DesignStrategos"},
        {"const": "VerificationArchitect"},
        {"const": "RiskScribe"}
      ],
      "items": {"type": "string"},
      "minItems": 5
    },
    "problem_statement": {
      "type": "object",
      "required": ["intent", "task_kinds", "known_constraints", "explicit_path_hints", "definition_of_done"]
    },
    "task_triage": {
      "type": "object",
      "required": ["task_kinds", "risk_level", "risk_score", "needs_clarification", "required_artifacts", "handoff_to"],
      "properties": {
        "risk_level": {"enum": ["low", "medium", "high"]},
        "handoff_to": {"const": "RepoSurveyor"}
      }
    },
    "repo_survey_request": {
      "type": "object",
      "required": ["repo_path", "read_only", "path_hints", "focus", "exclude_patterns", "expected_output", "handoff_to"],
      "properties": {
        "read_only": {"const": true},
        "expected_output": {"const": "repo_survey.json"},
        "handoff_to": {"const": "DesignStrategos"}
      }
    },
    "dependency_map": {
      "type": "object",
      "required": ["nodes", "critical_path", "blocked_without", "survey_reference"]
    },
    "work_breakdown": {
      "type": "object",
      "required": ["risk_level", "phases", "critical_path", "parallelizable_after_survey", "stop_conditions"]
    },
    "impact_analysis": {
      "type": "object",
      "required": ["surfaces", "highest_risk_surface", "requires_cross_surface_review"]
    },
    "execution_forecast": {
      "type": "object",
      "required": ["complexity", "complexity_score", "expected_code_brigade_iterations", "recommended_timeout_minutes", "escalation_triggers"],
      "properties": {
        "complexity": {"enum": ["low", "medium", "high"]}
      }
    },
    "design_options": {
      "type": "object",
      "required": ["options", "selected_strategy", "requires_ceraxia_approval", "handoff_to"],
      "properties": {
        "requires_ceraxia_approval": {"const": true},
        "handoff_to": {"const": "VerificationArchitect"}
      }
    },
    "verification_strategy": {
      "type": "object",
      "required": ["targeted_commands", "checks", "negative_tests", "broad_verification_required", "broad_verification_or_blocker", "handoff_to"],
      "properties": {
        "handoff_to": {"const": "RiskScribe"}
      }
    },
    "surface_verification_matrix": {
      "type": "object",
      "required": ["rows", "complete", "blockers"]
    },
    "risk_register": {
      "type": "object",
      "required": ["risks", "acceptance_gates", "handoff_to"],
      "properties": {
        "handoff_to": {"const": "Ceraxia"}
      }
    },
    "quality_bar": {
      "type": "object",
      "required": ["must_have_evidence", "forbidden_shortcuts", "success_definition"]
    },
    "acceptance_contract": {
      "type": "object",
      "required": ["must_prove", "review_questions"]
    },
    "implementation_brief_blueprint": {
      "type": "object",
      "required": ["target", "required_sections", "mutation_preconditions", "dependency_critical_path", "work_phases"],
      "properties": {
        "target": {"const": "CodeBrigade"}
      }
    },
    "implementation_work_packages": {
      "type": "object",
      "required": ["packages", "review_order", "global_handoff_criteria"],
      "properties": {
        "packages": {
          "type": "array",
          "minItems": 3
        },
        "review_order": {
          "type": "array",
          "minItems": 3
        },
        "global_handoff_criteria": {
          "type": "array",
          "minItems": 3
        }
      }
    },
    "planning_review_gate": {
      "type": "object",
      "required": ["decision", "score", "blockers", "warnings"],
      "properties": {
        "decision": {"enum": ["ready_for_ceraxia_review", "revise", "blocked"]}
      }
    },
    "code_brigade_handoff": {
      "type": "object",
      "required": ["target", "steps"],
      "properties": {
        "target": {"const": "CodeBrigade"}
      }
    },
    "next_action": {
      "type": "object",
      "required": ["owner", "action", "reason"],
      "properties": {
        "owner": {"const": "Ceraxia"}
      }
    }
  }
}
