{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia Planning Packet",
  "type": "object",
  "required": [
    "ok",
    "contract_version",
    "worker",
    "kind",
    "task",
    "roles_completed",
    "problem_statement",
    "task_triage",
    "repo_survey_request",
    "assumption_register",
    "investigation_playbook",
    "dependency_map",
    "work_breakdown",
    "impact_analysis",
    "execution_forecast",
    "expert_quality_plan",
    "change_control_plan",
    "design_options",
    "verification_strategy",
    "diagnostic_repair_plan",
    "surface_verification_matrix",
    "surface_package_matrix",
    "risk_register",
    "quality_bar",
    "acceptance_contract",
    "acceptance_trace_matrix",
    "constraint_trace_matrix",
    "implementation_brief_blueprint",
    "implementation_work_packages",
    "planning_review_gate",
    "code_brigade_handoff",
    "next_action"
  ],
  "properties": {
    "ok": {"type": "boolean"},
    "contract_version": {"const": "eye-mechanicum.v1"},
    "worker": {"const": "PlanningBrigade"},
    "kind": {"const": "ceraxia_planning_packet"},
    "task": {"type": "string"},
    "roles_completed": {
      "type": "array",
      "prefixItems": [
        {"const": "TaskTriage"},
        {"const": "RepoSurveyor"},
        {"const": "DesignStrategos"},
        {"const": "VerificationArchitect"},
        {"const": "RiskScribe"}
      ],
      "items": {"type": "string"},
      "minItems": 5
    },
    "problem_statement": {
      "type": "object",
      "required": ["intent", "task_kinds", "known_constraints", "explicit_path_hints", "definition_of_done"]
    },
    "task_triage": {
      "type": "object",
      "required": ["task_kinds", "risk_level", "risk_score", "needs_clarification", "required_artifacts", "handoff_to"],
      "properties": {
        "risk_level": {"enum": ["low", "medium", "high"]},
        "handoff_to": {"const": "RepoSurveyor"}
      }
    },
    "repo_survey_request": {
      "type": "object",
      "required": ["repo_path", "read_only", "path_hints", "focus", "exclude_patterns", "expected_output", "handoff_to"],
      "properties": {
        "read_only": {"const": true},
        "expected_output": {"const": "repo_survey.json"},
        "handoff_to": {"const": "DesignStrategos"}
      }
    },
    "assumption_register": {
      "type": "object",
      "required": ["assumptions", "replan_when_false", "handoff_to"],
      "properties": {
        "assumptions": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["id", "assumption", "risk_if_false", "validation_source", "blocks_when_false", "owner"]
          }
        },
        "replan_when_false": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "handoff_to": {"const": "CodeBrigade"}
      }
    },
    "investigation_playbook": {
      "type": "object",
      "required": ["target", "read_stages", "evidence_questions", "mutation_blockers", "replan_triggers", "handoff_to"],
      "properties": {
        "target": {"const": "CodeBrigade"},
        "read_stages": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["stage", "must_collect", "blocks_mutation_until"]
          }
        },
        "evidence_questions": {
          "type": "array",
          "minItems": 4,
          "items": {"type": "string"}
        },
        "mutation_blockers": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "replan_triggers": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "handoff_to": {"const": "CodeBrigade"}
      }
    },
    "dependency_map": {
      "type": "object",
      "required": ["nodes", "critical_path", "blocked_without", "survey_reference"]
    },
    "work_breakdown": {
      "type": "object",
      "required": ["risk_level", "phases", "critical_path", "parallelizable_after_survey", "stop_conditions"]
    },
    "impact_analysis": {
      "type": "object",
      "required": ["surfaces", "highest_risk_surface", "requires_cross_surface_review"]
    },
    "execution_forecast": {
      "type": "object",
      "required": ["complexity", "complexity_score", "expected_code_brigade_iterations", "recommended_timeout_minutes", "escalation_triggers"],
      "properties": {
        "complexity": {"enum": ["low", "medium", "high"]}
      }
    },
    "expert_quality_plan": {
      "type": "object",
      "required": ["level", "required_for_expert_gate", "tradeoff_register", "rollback_strategy", "observability_plan", "review_checklist", "escalation_policy"],
      "properties": {
        "level": {"enum": ["standard", "expert"]},
        "required_for_expert_gate": {"type": "boolean"},
        "tradeoff_register": {
          "type": "array",
          "minItems": 2
        },
        "rollback_strategy": {
          "type": "array",
          "minItems": 2
        },
        "observability_plan": {
          "type": "array",
          "minItems": 2
        },
        "review_checklist": {
          "type": "array",
          "minItems": 4
        },
        "escalation_policy": {
          "type": "array",
          "minItems": 2
        }
      }
    },
    "change_control_plan": {
      "type": "object",
      "required": ["target", "allowed_change_intents", "protected_invariants", "mutation_requires", "diff_review_questions", "rollback_triggers", "post_change_proofs", "handoff_to"],
      "properties": {
        "target": {"const": "CodeBrigade"},
        "allowed_change_intents": {"type": "array", "minItems": 3, "items": {"type": "string"}},
        "protected_invariants": {"type": "array", "minItems": 3, "items": {"type": "string"}},
        "mutation_requires": {"type": "array", "minItems": 4, "items": {"type": "string"}},
        "diff_review_questions": {"type": "array", "minItems": 3, "items": {"type": "string"}},
        "rollback_triggers": {"type": "array", "minItems": 3, "items": {"type": "string"}},
        "post_change_proofs": {"type": "array", "minItems": 3, "items": {"type": "string"}},
        "handoff_to": {"const": "CodeBrigade"}
      }
    },
    "design_options": {
      "type": "object",
      "required": ["options", "selected_strategy", "requires_ceraxia_approval", "handoff_to"],
      "properties": {
        "requires_ceraxia_approval": {"const": true},
        "handoff_to": {"const": "VerificationArchitect"}
      }
    },
    "verification_strategy": {
      "type": "object",
      "required": ["targeted_commands", "checks", "negative_tests", "broad_verification_required", "broad_verification_or_blocker", "handoff_to"],
      "properties": {
        "handoff_to": {"const": "RiskScribe"}
      }
    },
    "diagnostic_repair_plan": {
      "type": "object",
      "required": ["target", "max_repair_attempts", "diagnostic_inputs_required", "read_before_repair", "stop_conditions", "repair_evidence_required", "scope_budget", "requires_ceraxia_review_after_each_attempt", "handoff_to"],
      "properties": {
        "target": {"const": "CodeBrigade"},
        "max_repair_attempts": {"const": 3},
        "diagnostic_inputs_required": {
          "type": "array",
          "minItems": 4,
          "items": {"type": "string"}
        },
        "read_before_repair": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "stop_conditions": {
          "type": "array",
          "minItems": 4,
          "items": {"type": "string"}
        },
        "repair_evidence_required": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "scope_budget": {"type": "object"},
        "requires_ceraxia_review_after_each_attempt": {"type": "boolean"},
        "handoff_to": {"const": "CodeBrigade"}
      }
    },
    "surface_verification_matrix": {
      "type": "object",
      "required": ["rows", "complete", "blockers"]
    },
    "risk_register": {
      "type": "object",
      "required": ["risks", "acceptance_gates", "handoff_to"],
      "properties": {
        "handoff_to": {"const": "Ceraxia"}
      }
    },
    "quality_bar": {
      "type": "object",
      "required": ["must_have_evidence", "forbidden_shortcuts", "success_definition"]
    },
    "acceptance_contract": {
      "type": "object",
      "required": ["must_prove", "review_questions"]
    },
    "acceptance_trace_matrix": {
      "type": "object",
      "required": ["rows", "row_count", "complete", "blockers"],
      "properties": {
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["requirement", "source", "linked_surfaces", "package_ids", "planned_evidence", "status"]
          }
        },
        "complete": {"const": true}
      }
    },
    "constraint_trace_matrix": {
      "type": "object",
      "required": ["rows", "row_count", "complete", "blockers"],
      "properties": {
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["constraint", "source", "package_ids", "planned_evidence", "status"]
          }
        },
        "complete": {"const": true}
      }
    },
    "implementation_brief_blueprint": {
      "type": "object",
      "required": ["target", "required_sections", "mutation_preconditions", "dependency_critical_path", "work_phases", "change_control_invariants", "change_control_post_change_proofs"],
      "properties": {
        "target": {"const": "CodeBrigade"}
      }
    },
    "implementation_work_packages": {
      "type": "object",
      "required": ["packages", "review_order", "package_dependency_graph", "global_handoff_criteria"],
      "properties": {
        "packages": {
          "type": "array",
          "minItems": 3
        },
        "review_order": {
          "type": "array",
          "minItems": 3
        },
        "global_handoff_criteria": {
          "type": "array",
          "minItems": 3
        },
        "package_dependency_graph": {
          "type": "object",
          "required": ["rows", "root_packages", "terminal_packages", "parallelizable_after_survey", "complete", "blockers"],
          "properties": {
            "rows": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "object",
                "required": ["package_id", "depends_on", "dependency_reason"]
              }
            },
            "root_packages": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            },
            "terminal_packages": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            },
            "parallelizable_after_survey": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            },
            "complete": {"const": true},
            "blockers": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "surface_package_matrix": {
      "type": "object",
      "required": ["rows", "complete", "blockers"],
      "properties": {
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["surface", "verification_evidence", "package_ids", "blockers"],
            "properties": {
              "surface": {"type": "string"},
              "verification_evidence": {
                "type": "array",
                "items": {"type": "string"}
              },
              "package_ids": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string"}
              },
              "blockers": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        },
        "complete": {"type": "boolean"},
        "blockers": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "planning_review_gate": {
      "type": "object",
      "required": ["decision", "score", "blockers", "warnings"],
      "properties": {
        "decision": {"enum": ["ready_for_ceraxia_review", "revise", "blocked"]}
      }
    },
    "code_brigade_handoff": {
      "type": "object",
      "required": ["target", "steps", "package_review_order", "package_dependency_graph", "global_handoff_criteria", "diagnostic_repair_plan", "acceptance_trace_required", "acceptance_trace_row_count", "required_quality_evidence"],
      "properties": {
        "target": {"const": "CodeBrigade"},
        "steps": {
          "type": "array",
          "minItems": 1
        },
        "package_review_order": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "package_dependency_graph": {
          "type": "object",
          "required": ["rows", "root_packages", "terminal_packages", "parallelizable_after_survey", "complete", "blockers"]
        },
        "global_handoff_criteria": {
          "type": "array",
          "minItems": 3,
          "items": {"type": "string"}
        },
        "diagnostic_repair_plan": {"type": "object"},
        "acceptance_trace_required": {"const": true},
        "acceptance_trace_row_count": {
          "type": "integer",
          "minimum": 1
        },
        "required_quality_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    },
    "next_action": {
      "type": "object",
      "required": ["owner", "action", "reason"],
      "properties": {
        "owner": {"const": "Ceraxia"}
      }
    }
  }
}
