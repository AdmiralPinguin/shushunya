{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanningBrigade Feedback Intake",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "run_id",
    "status",
    "target",
    "source",
    "task",
    "repo_path",
    "validation_problems",
    "feedback_finding_count",
    "replan_focus",
    "required_return_artifacts",
    "replan_payload",
    "recommended_planning_actions",
    "handoff_back_to"
  ],
  "properties": {
    "kind": {
      "const": "planning_brigade_feedback_intake"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": ["blocked_invalid_request", "replan_required", "no_replan_required"]
    },
    "target": {
      "const": "PlanningBrigade"
    },
    "source": {
      "const": "planning_feedback_request.json"
    },
    "task": {
      "type": "string"
    },
    "repo_path": {
      "type": "string"
    },
    "validation_problems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "feedback_finding_count": {
      "type": "integer"
    },
    "replan_focus": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_return_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replan_payload": {
      "type": "object",
      "required": ["task", "repo_path", "constraints", "requirements", "source_run_id", "source_feedback_status"],
      "properties": {
        "task": {
          "type": "string"
        },
        "repo_path": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_run_id": {
          "type": "string"
        },
        "source_feedback_status": {
          "type": "string"
        }
      }
    },
    "recommended_planning_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "reason", "required_when"]
      }
    },
    "handoff_back_to": {
      "const": "Ceraxia"
    }
  },
  "additionalProperties": false
}
