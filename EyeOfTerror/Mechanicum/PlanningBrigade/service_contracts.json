{
  "kind": "planning_brigade_service_contracts",
  "contract_version": "eye-mechanicum.v1",
  "status": "planned_interfaces_in_process_implementation",
  "base_path": "EyeOfTerror/Mechanicum/PlanningBrigade",
  "port_policy": {
    "host": "127.0.0.1",
    "reserved_range": "7111-7115",
    "active": false,
    "reason": "Planning roles stay in-process until field trials prove the service split."
  },
  "shared_endpoints": [
    "GET /health",
    "GET /capabilities",
    "POST /plan"
  ],
  "services": [
    {
      "name": "TaskTriage",
      "port": 7111,
      "authority": "classify task intent and risk before repository mutation",
      "input_artifacts": ["task", "constraints"],
      "output_artifacts": ["problem_statement", "task_triage"],
      "may_mutate_source": false,
      "handoff_to": "RepoSurveyor"
    },
    {
      "name": "RepoSurveyor",
      "port": 7112,
      "authority": "request and consume read-only repository evidence",
      "input_artifacts": ["problem_statement", "task_triage"],
      "output_artifacts": ["repo_survey_request", "assumption_register", "dependency_map"],
      "may_mutate_source": false,
      "handoff_to": "DesignStrategos"
    },
    {
      "name": "DesignStrategos",
      "port": 7113,
      "authority": "select the smallest coherent design and impacted surfaces",
      "input_artifacts": ["problem_statement", "repo_survey_request", "dependency_map", "assumption_register"],
      "output_artifacts": ["work_breakdown", "impact_analysis", "investigation_playbook", "design_options", "execution_forecast", "expert_quality_plan", "change_control_plan"],
      "may_mutate_source": false,
      "handoff_to": "VerificationArchitect"
    },
    {
      "name": "VerificationArchitect",
      "port": 7114,
      "authority": "map impacted surfaces to verification evidence",
      "input_artifacts": ["impact_analysis", "design_options", "change_control_plan"],
      "output_artifacts": ["verification_strategy", "surface_verification_matrix"],
      "may_mutate_source": false,
      "handoff_to": "RiskScribe"
    },
    {
      "name": "RiskScribe",
      "port": 7115,
      "authority": "record risks, acceptance gates, traceability, and CodeBrigade handoff constraints",
      "input_artifacts": ["verification_strategy", "surface_verification_matrix", "impact_analysis", "work_breakdown", "change_control_plan"],
      "output_artifacts": ["risk_register", "quality_bar", "acceptance_contract", "acceptance_trace_matrix", "constraint_trace_matrix", "implementation_brief_blueprint", "implementation_work_packages", "surface_package_matrix", "planning_review_gate", "code_brigade_handoff"],
      "may_mutate_source": false,
      "handoff_to": "Ceraxia"
    }
  ],
  "split_gates": [
    "role_contracts.json and service_contracts.json agree on role order",
    "every service output appears in a valid planning packet",
    "service ports are unique and outside active worker registry ports",
    "all service interfaces remain read-only",
    "Ceraxia remains the authority that approves or revises the final planning packet"
  ]
}
