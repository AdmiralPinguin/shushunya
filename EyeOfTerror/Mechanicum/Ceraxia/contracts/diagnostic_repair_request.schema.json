{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Diagnostic Repair Request",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "run_id",
    "status",
    "target",
    "repo_path",
    "task",
    "verification_status",
    "review_decision",
    "diagnostic_repair_plan",
    "diagnostic_repair_queue",
    "suggested_code_brigade_command",
    "target_files_to_inspect",
    "test_files_to_preserve",
    "reverse_dependency_index",
    "scope_budget",
    "return_contract"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_diagnostic_repair_request"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": ["required", "not_required"]
    },
    "target": {
      "const": "CodeBrigade"
    },
    "repo_path": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "verification_status": {
      "type": "string"
    },
    "review_decision": {
      "type": "string"
    },
    "diagnostic_repair_plan": {
      "type": "object"
    },
    "diagnostic_repair_queue": {
      "type": "object",
      "required": ["status", "item_count", "items", "source", "plan_present"],
      "properties": {
        "status": {
          "enum": ["queued", "empty"]
        },
        "item_count": {
          "type": "integer"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "command",
              "status",
              "priority",
              "failure_classification",
              "diagnostic_signals",
              "impacted_surfaces",
              "package_ids",
              "traceback_files",
              "missing_imports",
              "source_candidates",
              "repair_hypotheses",
              "read_before_repair",
              "concrete_read_targets",
              "stop_conditions",
              "repair_evidence_required",
              "max_repair_attempts"
            ]
          }
        },
        "source": {
          "const": "verification_output_diagnostics"
        },
        "plan_present": {
          "type": "boolean"
        }
      }
    },
    "suggested_code_brigade_command": {
      "type": "array",
      "prefixItems": [
        {"const": "python3"},
        {"const": "EyeOfTerror/Mechanicum/CodeBrigade/diagnostic_repair_contract.py"},
        {"const": "--execute"},
        {"const": "diagnostic_repair_request.json"}
      ],
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "target_files_to_inspect": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_files_to_preserve": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reverse_dependency_index": {
      "type": "object"
    },
    "scope_budget": {
      "type": "object"
    },
    "return_contract": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
