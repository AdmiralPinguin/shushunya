{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Implementation Brief",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "owner",
    "target",
    "task",
    "repo_path",
    "task_kinds",
    "risk_level",
    "selected_strategy",
    "allowed_scope",
    "forbidden_approaches",
    "expected_artifacts",
    "required_verification",
    "surface_verification_matrix",
    "surface_package_matrix",
    "survey_quality_gate",
    "acceptance_gates",
    "quality_bar",
    "acceptance_contract",
    "implementation_brief_blueprint",
    "implementation_work_packages",
    "planning_review_gate",
    "planning_dependency_map",
    "work_breakdown",
    "impact_analysis",
    "execution_forecast",
    "code_brigade_handoff",
    "blocked",
    "blockers"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_implementation_brief"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "owner": {
      "const": "Ceraxia"
    },
    "target": {
      "const": "CodeBrigade"
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "task_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "risk_level": {
      "enum": ["low", "medium", "high"]
    },
    "selected_strategy": {
      "type": "string",
      "minLength": 1
    },
    "allowed_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "forbidden_approaches": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "required_verification": {
      "type": "object"
    },
    "surface_verification_matrix": {
      "type": "object"
    },
    "surface_package_matrix": {
      "type": "object"
    },
    "survey_quality_gate": {
      "type": "object"
    },
    "acceptance_gates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "quality_bar": {
      "type": "object"
    },
    "acceptance_contract": {
      "type": "object"
    },
    "implementation_brief_blueprint": {
      "type": "object"
    },
    "implementation_work_packages": {
      "type": "object"
    },
    "planning_review_gate": {
      "type": "object"
    },
    "planning_dependency_map": {
      "type": "object"
    },
    "work_breakdown": {
      "type": "object"
    },
    "impact_analysis": {
      "type": "object"
    },
    "execution_forecast": {
      "type": "object"
    },
    "code_brigade_handoff": {
      "type": "object"
    },
    "blocked": {
      "type": "boolean"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
