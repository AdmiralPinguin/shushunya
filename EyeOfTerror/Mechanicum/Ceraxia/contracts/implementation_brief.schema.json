{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Implementation Brief",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "owner",
    "target",
    "task",
    "repo_path",
    "task_kinds",
    "risk_level",
    "selected_strategy",
    "allowed_scope",
    "forbidden_approaches",
    "expected_artifacts",
    "required_verification",
    "surface_verification_matrix",
    "surface_package_matrix",
    "survey_quality_gate",
    "acceptance_gates",
    "quality_bar",
    "acceptance_contract",
    "expert_quality_plan",
    "investigation_playbook",
    "implementation_brief_blueprint",
    "implementation_work_packages",
    "planning_review_gate",
    "planning_dependency_map",
    "work_breakdown",
    "impact_analysis",
    "execution_forecast",
    "execution_intent",
    "code_brigade_handoff",
    "blocked",
    "blockers"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_implementation_brief"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "owner": {
      "const": "Ceraxia"
    },
    "target": {
      "const": "CodeBrigade"
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "task_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "risk_level": {
      "enum": ["low", "medium", "high"]
    },
    "selected_strategy": {
      "type": "string",
      "minLength": 1
    },
    "allowed_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "forbidden_approaches": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "required_verification": {
      "type": "object"
    },
    "surface_verification_matrix": {
      "type": "object"
    },
    "surface_package_matrix": {
      "type": "object"
    },
    "survey_quality_gate": {
      "type": "object"
    },
    "acceptance_gates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "quality_bar": {
      "type": "object"
    },
    "acceptance_contract": {
      "type": "object"
    },
    "expert_quality_plan": {
      "type": "object",
      "required": ["level", "required_for_expert_gate", "tradeoff_register", "rollback_strategy", "observability_plan", "review_checklist", "escalation_policy"],
      "properties": {
        "level": {
          "enum": ["standard", "expert"]
        },
        "required_for_expert_gate": {
          "type": "boolean"
        },
        "tradeoff_register": {
          "type": "array",
          "minItems": 2
        },
        "rollback_strategy": {
          "type": "array",
          "minItems": 2
        },
        "observability_plan": {
          "type": "array",
          "minItems": 2
        },
        "review_checklist": {
          "type": "array",
          "minItems": 4
        },
        "escalation_policy": {
          "type": "array",
          "minItems": 2
        }
      }
    },
    "investigation_playbook": {
      "type": "object",
      "required": ["target", "read_stages", "evidence_questions", "mutation_blockers", "replan_triggers"],
      "properties": {
        "target": {
          "const": "CodeBrigade"
        },
        "read_stages": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object"
          }
        },
        "evidence_questions": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "mutation_blockers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "replan_triggers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "implementation_brief_blueprint": {
      "type": "object"
    },
    "implementation_work_packages": {
      "type": "object"
    },
    "planning_review_gate": {
      "type": "object"
    },
    "planning_dependency_map": {
      "type": "object"
    },
    "work_breakdown": {
      "type": "object"
    },
    "impact_analysis": {
      "type": "object"
    },
    "execution_forecast": {
      "type": "object"
    },
    "execution_intent": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "mode",
        "adapter_capability",
        "explicit_patch_present",
        "real_execution_supported",
        "dry_run_requested",
        "blockers",
        "required_next_adapter"
      ],
      "properties": {
        "kind": {
          "const": "ceraxia_code_brigade_execution_intent"
        },
        "contract_version": {
          "const": "eye-mechanicum.v1"
        },
        "mode": {
          "enum": ["planning_handoff_only", "explicit_patch_execution", "guarded_inferred_patch_execution"]
        },
        "adapter_capability": {
          "enum": ["explicit_patch_adapter_only", "explicit_or_guarded_inference_adapter"]
        },
        "explicit_patch_present": {
          "type": "boolean"
        },
        "real_execution_supported": {
          "type": "boolean"
        },
        "dry_run_requested": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_next_adapter": {
          "type": "string"
        }
      }
    },
    "code_brigade_handoff": {
      "type": "object"
    },
    "blocked": {
      "type": "boolean"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
