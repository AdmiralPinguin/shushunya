{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Implementation Brief",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "owner",
    "target",
    "task",
    "repo_path",
    "task_kinds",
    "risk_level",
    "selected_strategy",
    "assumption_register",
    "allowed_scope",
    "forbidden_approaches",
    "expected_artifacts",
    "required_verification",
    "diagnostic_repair_plan",
    "surface_verification_matrix",
    "surface_package_matrix",
    "survey_quality_gate",
    "acceptance_gates",
    "quality_bar",
    "acceptance_contract",
    "acceptance_trace_matrix",
    "constraint_trace_matrix",
    "expert_quality_plan",
    "change_control_plan",
    "investigation_playbook",
    "implementation_brief_blueprint",
    "implementation_work_packages",
    "worker_output_contract",
    "planning_review_gate",
    "planning_dependency_map",
    "work_breakdown",
    "impact_analysis",
    "execution_forecast",
    "execution_intent",
    "code_brigade_handoff",
    "blocked",
    "blockers"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_implementation_brief"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "owner": {
      "const": "Ceraxia"
    },
    "target": {
      "const": "CodeBrigade"
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "task_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "risk_level": {
      "enum": ["low", "medium", "high"]
    },
    "selected_strategy": {
      "type": "string",
      "minLength": 1
    },
    "assumption_register": {
      "type": "object",
      "required": ["assumptions", "replan_when_false"],
      "properties": {
        "assumptions": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["id", "assumption", "risk_if_false", "validation_source", "blocks_when_false", "owner"]
          }
        },
        "replan_when_false": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "allowed_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "forbidden_approaches": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "required_verification": {
      "type": "object"
    },
    "diagnostic_repair_plan": {
      "type": "object",
      "required": ["target", "max_repair_attempts", "diagnostic_inputs_required", "read_before_repair", "stop_conditions", "repair_evidence_required", "handoff_to"],
      "properties": {
        "target": {
          "const": "CodeBrigade"
        },
        "max_repair_attempts": {
          "const": 3
        },
        "diagnostic_inputs_required": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "read_before_repair": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "stop_conditions": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "repair_evidence_required": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "handoff_to": {
          "const": "CodeBrigade"
        }
      }
    },
    "surface_verification_matrix": {
      "type": "object",
      "required": ["rows", "complete", "blockers"],
      "properties": {
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["surface", "risk", "evidence_needed", "covered_by", "output_evidence_required", "blockers"],
            "properties": {
              "output_evidence_required": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "surface_package_matrix": {
      "type": "object"
    },
    "survey_quality_gate": {
      "type": "object"
    },
    "acceptance_gates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "quality_bar": {
      "type": "object"
    },
    "acceptance_contract": {
      "type": "object"
    },
    "acceptance_trace_matrix": {
      "type": "object",
      "required": ["rows", "row_count", "definition_of_done_count", "traced_definition_of_done_count", "definition_of_done_complete", "missing_definition_of_done", "complete", "blockers"],
      "properties": {
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["requirement", "source", "linked_surfaces", "package_ids", "planned_evidence", "status"]
          }
        },
        "definition_of_done_complete": {
          "const": true
        },
        "missing_definition_of_done": {
          "type": "array",
          "maxItems": 0
        },
        "complete": {
          "const": true
        }
      }
    },
    "constraint_trace_matrix": {
      "type": "object",
      "required": ["rows", "row_count", "complete", "blockers"],
      "properties": {
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["constraint", "source", "package_ids", "planned_evidence", "status"]
          }
        },
        "complete": {
          "const": true
        }
      }
    },
    "expert_quality_plan": {
      "type": "object",
      "required": ["level", "required_for_expert_gate", "tradeoff_register", "rollback_strategy", "observability_plan", "review_checklist", "escalation_policy"],
      "properties": {
        "level": {
          "enum": ["standard", "expert"]
        },
        "required_for_expert_gate": {
          "type": "boolean"
        },
        "tradeoff_register": {
          "type": "array",
          "minItems": 2
        },
        "rollback_strategy": {
          "type": "array",
          "minItems": 2
        },
        "observability_plan": {
          "type": "array",
          "minItems": 2
        },
        "review_checklist": {
          "type": "array",
          "minItems": 4
        },
        "escalation_policy": {
          "type": "array",
          "minItems": 2
        }
      }
    },
    "change_control_plan": {
      "type": "object",
      "required": ["target", "allowed_change_intents", "protected_invariants", "mutation_requires", "diff_review_questions", "rollback_triggers", "post_change_proofs"],
      "properties": {
        "target": {
          "const": "CodeBrigade"
        },
        "allowed_change_intents": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "protected_invariants": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "mutation_requires": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "diff_review_questions": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "rollback_triggers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "post_change_proofs": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "investigation_playbook": {
      "type": "object",
      "required": ["target", "read_stages", "evidence_questions", "mutation_blockers", "replan_triggers"],
      "properties": {
        "target": {
          "const": "CodeBrigade"
        },
        "read_stages": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object"
          }
        },
        "evidence_questions": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "mutation_blockers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "replan_triggers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "implementation_brief_blueprint": {
      "type": "object"
    },
    "implementation_work_packages": {
      "type": "object"
    },
    "worker_output_contract": {
      "type": "object",
      "required": ["target", "required_reports", "required_package_statuses", "package_result_contract", "final_review_inputs", "failure_contract", "handoff_to"],
      "properties": {
        "target": {
          "const": "CodeBrigade"
        },
        "required_reports": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "required_package_statuses": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "package_result_contract": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["package_id", "required_status_field", "allowed_statuses", "required_evidence_source", "acceptance_requirements", "acceptance_evidence", "blocker_contract"],
            "properties": {
              "acceptance_requirements": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string"}
              },
              "acceptance_evidence": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string"}
              }
            }
          }
        },
        "final_review_inputs": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "failure_contract": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "handoff_to": {
          "const": "CodeBrigade"
        }
      }
    },
    "planning_review_gate": {
      "type": "object"
    },
    "planning_dependency_map": {
      "type": "object"
    },
    "work_breakdown": {
      "type": "object"
    },
    "impact_analysis": {
      "type": "object"
    },
    "execution_forecast": {
      "type": "object"
    },
    "execution_intent": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "mode",
        "adapter_capability",
        "explicit_patch_present",
        "real_execution_supported",
        "dry_run_requested",
        "blockers",
        "required_next_adapter"
      ],
      "properties": {
        "kind": {
          "const": "ceraxia_code_brigade_execution_intent"
        },
        "contract_version": {
          "const": "eye-mechanicum.v1"
        },
        "mode": {
          "enum": ["planning_handoff_only", "explicit_patch_execution", "guarded_inferred_patch_execution"]
        },
        "adapter_capability": {
          "enum": ["explicit_patch_adapter_only", "explicit_or_guarded_inference_adapter"]
        },
        "explicit_patch_present": {
          "type": "boolean"
        },
        "real_execution_supported": {
          "type": "boolean"
        },
        "dry_run_requested": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_next_adapter": {
          "type": "string"
        }
      }
    },
    "code_brigade_handoff": {
      "type": "object"
    },
    "blocked": {
      "type": "boolean"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
