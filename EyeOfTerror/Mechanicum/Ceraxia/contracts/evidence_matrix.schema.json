{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia Evidence Matrix",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "decision",
    "required_evidence_count",
    "present_count",
    "planned_count",
    "blocked_count",
    "rows",
    "implementation_plan_sources",
    "implementation_work_package_summary",
    "surface_package_summary",
    "expert_quality_summary"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_evidence_matrix"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "decision": {
      "type": "string"
    },
    "required_evidence_count": {
      "type": "integer"
    },
    "present_count": {
      "type": "integer"
    },
    "planned_count": {
      "type": "integer"
    },
    "blocked_count": {
      "type": "integer"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "requirement",
          "status",
          "sources",
          "blocking_reason"
        ],
        "properties": {
          "requirement": {
            "type": "string"
          },
          "status": {
            "enum": ["present", "planned", "blocked"]
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocking_reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "implementation_plan_sources": {
      "type": "object",
      "required": [
        "target_files_to_inspect",
        "test_files_to_preserve",
        "investigation_read_stages",
        "investigation_evidence_questions",
        "investigation_mutation_blockers",
        "verification_commands"
      ]
    },
    "implementation_work_package_summary": {
      "type": "object",
      "required": [
        "package_count",
        "review_order",
        "covered_surfaces",
        "covered_surface_count",
        "status_counts",
        "statuses"
      ]
    },
    "surface_package_summary": {
      "type": "object",
      "required": [
        "surface_count",
        "rows"
      ],
      "properties": {
        "surface_count": {
          "type": "integer"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "expert_quality_summary": {
      "type": "object",
      "required": [
        "level",
        "required_for_expert_gate",
        "impact_surfaces",
        "tradeoff_count",
        "rollback_requirement_count",
        "observability_requirement_count",
        "review_checklist_count",
        "escalation_policy_count"
      ],
      "properties": {
        "level": {
          "enum": ["standard", "expert"]
        },
        "required_for_expert_gate": {
          "type": "boolean"
        },
        "impact_surfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tradeoff_count": {
          "type": "integer"
        },
        "rollback_requirement_count": {
          "type": "integer"
        },
        "observability_requirement_count": {
          "type": "integer"
        },
        "review_checklist_count": {
          "type": "integer"
        },
        "escalation_policy_count": {
          "type": "integer"
        }
      }
    }
  },
  "additionalProperties": true
}
