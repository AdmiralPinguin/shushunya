{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia Run Summary",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "run_id",
    "run_dir",
    "state",
    "package_ok",
    "package_lifecycle_finalized",
    "package_audit_decision",
    "ready_for_execution",
    "review_decision",
    "planning_review_decision",
    "planning_review_score",
    "planning_work_phase_count",
    "implementation_work_package_count",
    "implementation_work_package_surface_count",
    "implementation_work_package_review_order",
    "work_package_status_counts",
    "survey_quality_decision",
    "survey_quality_warning_count",
    "surface_verification_status",
    "surface_verification_surface_count",
    "investigation_playbook_status",
    "investigation_read_stage_count",
    "investigation_evidence_question_count",
    "investigation_mutation_blocker_count",
    "investigation_replan_trigger_count",
    "change_control_status",
    "change_control_allowed_intent_count",
    "change_control_protected_invariant_count",
    "change_control_mutation_requirement_count",
    "change_control_diff_review_question_count",
    "change_control_rollback_trigger_count",
    "change_control_post_change_proof_count",
    "acceptance_trace_status",
    "acceptance_trace_row_count",
    "acceptance_trace_blocked_row_count",
    "constraint_trace_status",
    "constraint_trace_row_count",
    "constraint_trace_blocked_row_count",
    "assumption_register_status",
    "assumption_count",
    "assumption_replan_trigger_count",
    "execution_readiness",
    "worker_status",
    "code_brigade_execution_policy_status",
    "code_brigade_execution_intent_mode",
    "code_brigade_execution_real_supported",
    "code_brigade_autonomous_execution_request_status",
    "code_brigade_execution_result_status",
    "code_brigade_execution_preflight_ok",
    "code_brigade_execution_preflight_blocker_count",
    "risk_level",
    "task_kinds",
    "selected_strategy",
    "expert_quality_level",
    "expert_quality_required",
    "expert_tradeoff_count",
    "expert_review_checklist_count",
    "scope_budget_max_source_files_to_edit",
    "scope_budget_max_unrequested_test_files_to_edit",
    "scope_budget_replan_trigger_count",
    "evidence",
    "blockers",
    "next_action",
    "maturity"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_run_summary"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "package_ok": {
      "type": "boolean"
    },
    "package_lifecycle_finalized": {
      "type": "boolean"
    },
    "package_audit_decision": {
      "type": "string"
    },
    "ready_for_execution": {
      "type": "boolean"
    },
    "review_decision": {
      "type": "string"
    },
    "planning_review_decision": {
      "type": "string"
    },
    "planning_review_score": {
      "type": "integer"
    },
    "planning_work_phase_count": {
      "type": "integer"
    },
    "implementation_work_package_count": {
      "type": "integer"
    },
    "implementation_work_package_surface_count": {
      "type": "integer"
    },
    "implementation_work_package_review_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "work_package_status_counts": {
      "type": "object",
      "required": [
        "planned",
        "implemented",
        "blocked"
      ]
    },
    "survey_quality_decision": {
      "type": "string"
    },
    "survey_quality_warning_count": {
      "type": "integer"
    },
    "surface_verification_status": {
      "type": "string"
    },
    "surface_verification_surface_count": {
      "type": "integer"
    },
    "investigation_playbook_status": {
      "type": "string"
    },
    "investigation_read_stage_count": {
      "type": "integer"
    },
    "investigation_evidence_question_count": {
      "type": "integer"
    },
    "investigation_mutation_blocker_count": {
      "type": "integer"
    },
    "investigation_replan_trigger_count": {
      "type": "integer"
    },
    "change_control_status": {
      "type": "string"
    },
    "change_control_allowed_intent_count": {
      "type": "integer"
    },
    "change_control_protected_invariant_count": {
      "type": "integer"
    },
    "change_control_mutation_requirement_count": {
      "type": "integer"
    },
    "change_control_diff_review_question_count": {
      "type": "integer"
    },
    "change_control_rollback_trigger_count": {
      "type": "integer"
    },
    "change_control_post_change_proof_count": {
      "type": "integer"
    },
    "acceptance_trace_status": {
      "type": "string"
    },
    "acceptance_trace_row_count": {
      "type": "integer"
    },
    "acceptance_trace_blocked_row_count": {
      "type": "integer"
    },
    "constraint_trace_status": {
      "type": "string"
    },
    "constraint_trace_row_count": {
      "type": "integer"
    },
    "constraint_trace_blocked_row_count": {
      "type": "integer"
    },
    "assumption_register_status": {
      "type": "string"
    },
    "assumption_count": {
      "type": "integer"
    },
    "assumption_replan_trigger_count": {
      "type": "integer"
    },
    "execution_readiness": {
      "type": "string"
    },
    "worker_status": {
      "type": "string"
    },
    "code_brigade_execution_policy_status": {
      "type": "string"
    },
    "code_brigade_execution_intent_mode": {
      "type": "string"
    },
    "code_brigade_execution_real_supported": {
      "type": "boolean"
    },
    "code_brigade_autonomous_execution_request_status": {
      "type": "string"
    },
    "code_brigade_execution_result_status": {
      "type": "string"
    },
    "code_brigade_execution_preflight_blocker_count": {
      "type": "integer"
    },
    "code_brigade_execution_preflight_ok": {
      "type": ["boolean", "null"]
    },
    "risk_level": {
      "type": "string"
    },
    "task_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selected_strategy": {
      "type": "string"
    },
    "expert_quality_level": {
      "enum": ["standard", "expert"]
    },
    "expert_quality_required": {
      "type": "boolean"
    },
    "expert_tradeoff_count": {
      "type": "integer"
    },
    "expert_review_checklist_count": {
      "type": "integer"
    },
    "scope_budget_max_source_files_to_edit": {
      "type": "integer"
    },
    "scope_budget_max_unrequested_test_files_to_edit": {
      "type": "integer"
    },
    "scope_budget_replan_trigger_count": {
      "type": "integer"
    },
    "evidence": {
      "type": "object",
      "required": [
        "required_count",
        "present_count",
        "planned_count",
        "blocked_count"
      ],
      "properties": {
        "required_count": {
          "type": "integer"
        },
        "present_count": {
          "type": "integer"
        },
        "planned_count": {
          "type": "integer"
        },
        "blocked_count": {
          "type": "integer"
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    },
    "maturity": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
