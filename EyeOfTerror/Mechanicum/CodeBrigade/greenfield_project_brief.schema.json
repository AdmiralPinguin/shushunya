{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Greenfield Project Brief",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "project_name",
    "project_type",
    "template_id",
    "stack",
    "entrypoints",
    "expected_files",
    "files",
    "verification_commands",
    "run_commands",
    "artifact_contract",
    "workspace_policy",
    "definition_of_done",
    "architecture_plan",
    "file_tree_plan",
    "module_contracts",
    "verification_plan",
    "dependency_plan"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_greenfield_project_brief"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "project_type": {
      "enum": ["web_app", "api_service", "cli_tool", "library", "bot", "android_app", "game", "automation_tool"]
    },
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "stack": {
      "type": "object",
      "required": ["language", "framework", "package_manager", "runtime"]
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1
    },
    "expected_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1
    },
    "verification_commands": {
      "type": "array"
    },
    "run_commands": {
      "type": "array",
      "minItems": 1
    },
    "artifact_contract": {
      "type": "object",
      "required": ["required", "source_files", "test_files", "manifest_files"]
    },
    "workspace_policy": {
      "type": "object",
      "required": ["marker", "allowed_when", "forbidden_when"],
      "properties": {
        "marker": {
          "const": ".ceraxia_greenfield_workspace"
        }
      }
    },
    "definition_of_done": {
      "type": "array",
      "minItems": 1
    },
    "architecture_plan": {
      "type": "object",
      "required": ["summary", "selected_template", "selection_reason", "mvp_boundaries", "anti_stub_policy"]
    },
    "file_tree_plan": {
      "type": "array",
      "minItems": 1
    },
    "module_contracts": {
      "type": "array",
      "minItems": 1
    },
    "verification_plan": {
      "type": "object",
      "required": ["commands", "run_commands", "smoke_checks", "loop_stop_conditions"]
    },
    "dependency_plan": {
      "type": "object",
      "required": ["package_manager", "install_commands", "manifest_files", "lockfile_policy"]
    }
  },
  "additionalProperties": true
}
