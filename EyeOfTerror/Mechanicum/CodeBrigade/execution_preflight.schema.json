{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Execution Preflight",
  "type": "object",
  "required": [
    "kind",
    "repo_path",
    "repo_exists",
    "repo_is_dir",
    "allowed_scope_count",
    "candidate_file_count",
    "existing_candidate_file_count",
    "missing_candidate_files",
    "unsafe_candidate_files",
    "symlink_candidate_files",
    "test_file_count",
    "existing_test_file_count",
    "missing_test_files",
    "unsafe_test_files",
    "symlink_test_files",
    "targeted_command_count",
    "suggested_command_count",
    "blockers",
    "ok"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_execution_preflight"
    },
    "repo_path": {
      "type": "string"
    },
    "repo_exists": {
      "type": "boolean"
    },
    "repo_is_dir": {
      "type": "boolean"
    },
    "allowed_scope_count": {
      "type": "integer"
    },
    "candidate_file_count": {
      "type": "integer"
    },
    "existing_candidate_file_count": {
      "type": "integer"
    },
    "missing_candidate_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unsafe_candidate_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "symlink_candidate_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_file_count": {
      "type": "integer"
    },
    "existing_test_file_count": {
      "type": "integer"
    },
    "missing_test_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unsafe_test_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "symlink_test_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targeted_command_count": {
      "type": "integer"
    },
    "suggested_command_count": {
      "type": "integer"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ok": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
