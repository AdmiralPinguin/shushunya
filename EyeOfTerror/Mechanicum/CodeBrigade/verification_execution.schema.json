{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Verification Execution",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "status",
    "execute",
    "repo_path",
    "results",
    "blockers",
    "contract_trace"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_verification_execution"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "status": {
      "enum": ["planned", "passed", "failed", "blocked"]
    },
    "execute": {
      "type": "boolean"
    },
    "repo_path": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status",
          "returncode",
          "stdout",
          "stderr"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "enum": ["planned", "passed", "failed", "blocked", "skipped"]
          },
          "returncode": {
            "type": ["integer", "null"]
          },
          "stdout": {
            "type": "string"
          },
          "stderr": {
            "type": "string"
          },
          "diagnostics": {
            "type": "object",
            "properties": {
              "has_traceback": {
                "type": "boolean"
              },
              "traceback_files": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "missing_imports": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "has_assertion_failure": {
                "type": "boolean"
              },
              "has_syntax_error": {
                "type": "boolean"
              },
              "has_no_tests_ran": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract_trace": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "requirement_count",
        "status",
        "status_counts",
        "focused_evidence_count",
        "behavior_evidence_count",
        "broad_evidence_count",
        "blocking_requirement_count",
        "falsification_review",
        "rows"
      ],
      "properties": {
        "kind": {
          "const": "code_brigade_verification_contract_trace"
        },
        "contract_version": {
          "const": "eye-mechanicum.v1"
        },
        "requirement_count": {
          "type": "integer"
        },
        "status": {
          "enum": ["proven", "incomplete"]
        },
        "status_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "focused_evidence_count": {
          "type": "integer"
        },
        "behavior_evidence_count": {
          "type": "integer"
        },
        "broad_evidence_count": {
          "type": "integer"
        },
        "blocking_requirement_count": {
          "type": "integer"
        },
        "falsification_review": {
          "type": "object",
          "required": ["kind", "contract_version", "status", "probe_count", "blocking_concern_count", "concerns", "probes"],
          "properties": {
            "kind": {
              "const": "code_brigade_falsification_review"
            },
            "contract_version": {
              "const": "eye-mechanicum.v1"
            },
            "status": {
              "enum": ["passed", "blocked"]
            },
            "probe_count": {
              "type": "integer"
            },
            "blocking_concern_count": {
              "type": "integer"
            },
            "concerns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "probes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["requirement", "status", "required_probe", "concerns"],
                "properties": {
                  "requirement": {
                    "type": "string"
                  },
                  "status": {
                    "enum": ["satisfied", "blocked"]
                  },
                  "required_probe": {
                    "type": "string"
                  },
                  "concerns": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["requirement", "status", "matched_commands", "command_kinds"],
            "properties": {
              "requirement": {
                "type": "string"
              },
              "status": {
                "enum": ["proven", "syntax_only", "planned_only", "blocked", "skipped", "failed", "missing"]
              },
              "matched_commands": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "command_kinds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
