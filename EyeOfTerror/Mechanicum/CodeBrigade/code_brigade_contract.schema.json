{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Worker Report Contract",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "target",
    "status",
    "dry_run",
    "changed_files",
    "implementation_plan",
    "execution_policy_status",
    "notes",
    "implementation_brief_acknowledged",
    "validation_problems",
    "adapter"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_worker_report"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "target": {
      "const": "CodeBrigade"
    },
    "status": {
      "enum": ["dry_run_handoff_ready", "implemented", "blocked"]
    },
    "dry_run": {
      "type": "boolean"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_plan": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "strategy",
        "risk_level",
        "target_files_to_inspect",
        "test_files_to_preserve",
        "path_hints",
        "existing_path_hints",
        "missing_path_hints",
        "unsafe_path_hints",
        "recommended_read_order",
        "source_summaries_to_consider",
        "dependency_edges_to_check",
        "survey_truncated",
        "python_symbols_truncated",
        "handoff_steps",
        "planning_critical_path",
        "planning_review_decision",
        "planning_review_score",
        "work_phases",
        "stop_conditions",
        "impact_surfaces",
        "highest_risk_surface",
        "requires_cross_surface_review",
        "execution_complexity",
        "expected_code_brigade_iterations",
        "recommended_timeout_minutes",
        "escalation_triggers",
        "mutation_preconditions",
        "implementation_work_packages",
        "work_package_review_order",
        "work_package_handoff_criteria",
        "acceptance_evidence_required",
        "verification_commands",
        "surface_verification_complete",
        "surface_verification_rows",
        "survey_quality_decision",
        "survey_quality_warnings",
        "acceptance_gates",
        "refusal_conditions"
      ],
      "properties": {
        "survey_truncated": {
          "type": "boolean"
        },
        "python_symbols_truncated": {
          "type": "boolean"
        },
        "path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "existing_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsafe_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_read_order": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "source_summaries_to_consider": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "planning_critical_path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "planning_review_decision": {
          "type": "string"
        },
        "planning_review_score": {
          "type": "integer"
        },
        "work_phases": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impact_surfaces": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "highest_risk_surface": {
          "type": "string"
        },
        "requires_cross_surface_review": {
          "type": "boolean"
        },
        "execution_complexity": {
          "type": "string"
        },
        "expected_code_brigade_iterations": {
          "type": "integer"
        },
        "recommended_timeout_minutes": {
          "type": "integer"
        },
        "escalation_triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mutation_preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "implementation_work_packages": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "work_package_review_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "work_package_handoff_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_evidence_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "surface_verification_complete": {
          "type": "boolean"
        },
        "surface_verification_rows": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "survey_quality_decision": {
          "type": "string"
        },
        "survey_quality_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "execution_policy_status": {
      "enum": ["blocked_until_adapter_is_wired", "real_execution_adapter_active"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_brief_acknowledged": {
      "type": "boolean"
    },
    "validation_problems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "adapter": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
