{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Worker Report Contract",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "target",
    "status",
    "dry_run",
    "changed_files",
    "implementation_plan",
    "work_package_statuses",
    "execution_policy_status",
    "notes",
    "implementation_brief_acknowledged",
    "validation_problems",
    "adapter"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_worker_report"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "target": {
      "const": "CodeBrigade"
    },
    "status": {
      "enum": ["dry_run_handoff_ready", "implemented", "blocked"]
    },
    "dry_run": {
      "type": "boolean"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_plan": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "strategy",
        "risk_level",
        "target_files_to_inspect",
        "test_files_to_preserve",
        "path_hints",
        "existing_path_hints",
        "missing_path_hints",
        "unsafe_path_hints",
        "recommended_read_order",
        "source_summaries_to_consider",
        "dependency_edges_to_check",
        "caller_candidates",
        "contract_surface_candidates",
        "survey_truncated",
        "python_symbols_truncated",
        "handoff_steps",
        "planning_critical_path",
        "planning_review_decision",
        "planning_review_score",
        "work_phases",
        "stop_conditions",
        "impact_surfaces",
        "highest_risk_surface",
        "requires_cross_surface_review",
        "execution_complexity",
        "expected_code_brigade_iterations",
        "recommended_timeout_minutes",
        "escalation_triggers",
        "mutation_preconditions",
        "implementation_work_packages",
        "work_package_review_order",
        "work_package_blocking_policies",
        "work_package_handoff_criteria",
        "acceptance_evidence_required",
        "acceptance_trace_rows",
        "acceptance_trace_complete",
        "expert_quality_level",
        "expert_quality_required",
        "expert_tradeoff_register",
        "expert_rollback_strategy",
        "expert_observability_plan",
        "expert_review_checklist",
        "expert_escalation_policy",
        "change_allowed_intents",
        "change_protected_invariants",
        "change_mutation_requires",
        "change_diff_review_questions",
        "change_rollback_triggers",
        "change_post_change_proofs",
        "investigation_read_stages",
        "investigation_evidence_questions",
        "investigation_mutation_blockers",
        "investigation_replan_triggers",
        "verification_commands",
        "surface_verification_complete",
        "surface_verification_rows",
        "surface_package_matrix_complete",
        "surface_package_matrix_rows",
        "survey_quality_decision",
        "survey_quality_warnings",
        "acceptance_gates",
        "refusal_conditions"
