        "planning_review_decision": {
          "type": "string"
        },
        "planning_review_score": {
          "type": "integer"
        },
        "work_phases": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impact_surfaces": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "highest_risk_surface": {
          "type": "string"
        },
        "requires_cross_surface_review": {
          "type": "boolean"
        },
        "execution_complexity": {
          "type": "string"
        },
        "expected_code_brigade_iterations": {
          "type": "integer"
        },
        "recommended_timeout_minutes": {
          "type": "integer"
        },
        "escalation_triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mutation_preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "implementation_work_packages": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "work_package_review_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "work_package_blocking_policies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "work_package_handoff_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_evidence_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_trace_rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "acceptance_trace_complete": {
          "type": "boolean"
        },
        "expert_quality_level": {
          "enum": ["standard", "expert"]
        },
        "expert_quality_required": {
          "type": "boolean"
        },
        "expert_tradeoff_register": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "expert_rollback_strategy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expert_observability_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expert_review_checklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expert_escalation_policy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "change_allowed_intents": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "change_protected_invariants": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "change_mutation_requires": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "change_diff_review_questions": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "change_rollback_triggers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "change_post_change_proofs": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "investigation_read_stages": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object"
          }
        },
        "investigation_evidence_questions": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "investigation_mutation_blockers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "investigation_replan_triggers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "surface_verification_complete": {
          "type": "boolean"
        },
        "surface_verification_rows": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "surface_package_matrix_complete": {
          "type": "boolean"
        },
        "surface_package_matrix_rows": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "survey_quality_decision": {
          "type": "string"
        },
        "survey_quality_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "work_package_statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "package_id",
          "owner",
          "impact_surfaces",
          "status",
          "evidence_source"
        ],
        "properties": {
          "package_id": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "impact_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "enum": ["planned", "implemented", "blocked"]
          },
          "evidence_source": {
            "type": "string"
          }
        }
      }
    },
    "execution_policy_status": {
      "enum": ["blocked_until_adapter_is_wired", "real_execution_adapter_active"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_brief_acknowledged": {
      "type": "boolean"
    },
    "validation_problems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "adapter": {
      "type": "string"
    }
