        "python_symbols_truncated": {
          "type": "boolean"
        },
        "path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "existing_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsafe_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_read_order": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "source_summaries_to_consider": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "caller_candidates": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "contract_surface_candidates": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
