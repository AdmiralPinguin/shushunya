{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ceraxia CodeBrigade Worker Report Contract",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "target",
    "status",
    "dry_run",
    "changed_files",
    "implementation_plan",
    "execution_policy_status",
    "notes",
    "implementation_brief_acknowledged",
    "validation_problems",
    "adapter"
  ],
  "properties": {
    "kind": {
      "const": "ceraxia_code_brigade_worker_report"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "target": {
      "const": "CodeBrigade"
    },
    "status": {
      "enum": ["dry_run_handoff_ready", "implemented", "blocked"]
    },
    "dry_run": {
      "type": "boolean"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_plan": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "strategy",
        "risk_level",
        "target_files_to_inspect",
        "test_files_to_preserve",
        "dependency_edges_to_check",
        "handoff_steps",
        "verification_commands",
        "acceptance_gates",
        "refusal_conditions"
      ]
    },
    "execution_policy_status": {
      "enum": ["blocked_until_adapter_is_wired", "real_execution_adapter_active"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_brief_acknowledged": {
      "type": "boolean"
    },
    "validation_problems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "adapter": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
