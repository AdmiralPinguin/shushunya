{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Verification Policy",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "execution_mode",
    "allowed_prefixes",
    "path_token_guards",
    "output_contract"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_verification_policy"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "execution_mode": {
      "const": "allowlisted_no_shell"
    },
    "allowed_prefixes": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "path_token_guards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_contract": {
      "const": "verification_execution.schema.json"
    }
  },
  "additionalProperties": true
}
