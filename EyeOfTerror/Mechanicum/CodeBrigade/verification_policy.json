{
  "kind": "code_brigade_verification_policy",
  "contract_version": "eye-mechanicum.v1",
  "execution_mode": "allowlisted_no_shell",
  "allowed_prefixes": [
    ["python", "-m", "py_compile"],
    ["python3", "-m", "py_compile"],
    ["python", "-m", "pytest"],
    ["python3", "-m", "pytest"],
    ["python", "-m", "unittest"],
    ["python3", "-m", "unittest"],
    ["pytest"],
    ["git", "diff", "--check"]
  ],
  "path_token_guards": [
    "block absolute path tokens",
    "block parent traversal tokens",
    "block option values that point outside the repository"
  ],
  "output_contract": "verification_execution.schema.json",
  "acceptance_trace_policy": "contract_trace must not treat py_compile or git diff --check as behavior proof"
}
