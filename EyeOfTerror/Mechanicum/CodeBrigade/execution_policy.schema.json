{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Execution Policy",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "default_mode",
    "real_execution_status",
    "mutation_preconditions",
    "forbidden_execution_shortcuts",
    "future_adapter_outputs"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_execution_policy"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "default_mode": {
      "const": "dry_run_handoff"
    },
    "real_execution_status": {
      "enum": ["blocked_until_adapter_is_wired", "explicit_patch_adapter_only", "explicit_or_guarded_inference_adapter", "real_execution_adapter_active"]
    },
    "mutation_preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_execution_shortcuts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "future_adapter_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
