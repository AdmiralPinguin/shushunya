{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Real Execution Result",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "status",
    "changed_files",
    "patch_summary",
    "verification_commands_executed",
    "blockers",
    "rollback_notes"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_execution_result"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "status": {
      "enum": ["implemented", "blocked", "rolled_back"]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_summary": {
      "type": "string"
    },
    "verification_commands_executed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_notes": {
      "type": "string"
    },
    "preflight": {
      "type": "object",
      "required": [
        "kind",
        "repo_path",
        "repo_exists",
        "repo_is_dir",
        "candidate_file_count",
        "existing_candidate_file_count",
        "missing_candidate_files",
        "test_file_count",
        "existing_test_file_count",
        "missing_test_files",
        "targeted_command_count",
        "suggested_command_count",
        "blockers",
        "ok"
      ],
      "properties": {
        "kind": {
          "const": "code_brigade_execution_preflight"
        },
        "repo_path": {
          "type": "string"
        },
        "repo_exists": {
          "type": "boolean"
        },
        "repo_is_dir": {
          "type": "boolean"
        },
        "candidate_file_count": {
          "type": "integer"
        },
        "existing_candidate_file_count": {
          "type": "integer"
        },
        "missing_candidate_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "test_file_count": {
          "type": "integer"
        },
        "existing_test_file_count": {
          "type": "integer"
        },
        "missing_test_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targeted_command_count": {
          "type": "integer"
        },
        "suggested_command_count": {
          "type": "integer"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ok": {
          "type": "boolean"
        }
      }
    }
  },
  "additionalProperties": true
}
