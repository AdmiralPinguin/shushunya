{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeBrigade Real Execution Result",
  "type": "object",
  "required": [
    "kind",
    "contract_version",
    "status",
    "changed_files",
    "patch_summary",
    "verification_commands_executed",
    "blockers",
    "rollback_notes",
    "operation_results",
    "patch_manifest"
  ],
  "properties": {
    "kind": {
      "const": "code_brigade_execution_result"
    },
    "contract_version": {
      "const": "eye-mechanicum.v1"
    },
    "status": {
      "enum": ["implemented", "blocked", "rolled_back"]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_summary": {
      "type": "string"
    },
    "verification_commands_executed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_notes": {
      "type": "string"
    },
    "operation_results": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "patch_manifest": {
      "type": "object",
      "required": [
        "kind",
        "contract_version",
        "changed_files",
        "files",
        "changed_file_count",
        "multi_file",
        "operation_count",
        "operation_counts",
        "failed_operation_count",
        "rollback_performed",
        "rollback_notes"
      ],
      "properties": {
        "kind": {
          "const": "code_brigade_patch_manifest"
        },
        "contract_version": {
          "const": "eye-mechanicum.v1"
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "operations", "applied_operation_count", "failed_operation_count", "rollback_touched", "before_sha256", "after_sha256"],
            "properties": {
              "path": {
                "type": "string"
              },
              "operations": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "applied_operation_count": {
                "type": "integer"
              },
              "failed_operation_count": {
                "type": "integer"
              },
              "rollback_touched": {
                "type": "boolean"
              },
              "before_sha256": {
                "type": "string"
              },
              "after_sha256": {
                "type": "string"
              }
            }
          }
        },
        "changed_file_count": {
          "type": "integer"
        },
        "multi_file": {
          "type": "boolean"
        },
        "operation_count": {
          "type": "integer"
        },
        "operation_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "failed_operation_count": {
          "type": "integer"
        },
        "rollback_performed": {
          "type": "boolean"
        },
        "rollback_notes": {
          "type": "string"
        }
      }
    },
    "preflight": {
      "type": "object",
      "required": [
        "kind",
        "repo_path",
        "repo_exists",
        "repo_is_dir",
        "candidate_file_count",
        "existing_candidate_file_count",
        "missing_candidate_files",
        "unsafe_candidate_files",
        "symlink_candidate_files",
        "test_file_count",
        "existing_test_file_count",
        "missing_test_files",
        "unsafe_test_files",
        "symlink_test_files",
        "allowed_new_files",
        "unsafe_missing_path_hints",
        "targeted_command_count",
        "suggested_command_count",
        "blockers",
        "ok"
      ],
      "properties": {
        "kind": {
          "const": "code_brigade_execution_preflight"
        },
        "repo_path": {
          "type": "string"
        },
        "repo_exists": {
          "type": "boolean"
        },
        "repo_is_dir": {
          "type": "boolean"
        },
        "candidate_file_count": {
          "type": "integer"
        },
        "existing_candidate_file_count": {
          "type": "integer"
        },
        "missing_candidate_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsafe_candidate_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "symlink_candidate_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "test_file_count": {
          "type": "integer"
        },
        "existing_test_file_count": {
          "type": "integer"
        },
        "missing_test_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsafe_test_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "symlink_test_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_new_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsafe_missing_path_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targeted_command_count": {
          "type": "integer"
        },
        "suggested_command_count": {
          "type": "integer"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ok": {
          "type": "boolean"
        }
      }
    }
  },
  "additionalProperties": true
}
