{
  "schema_version": 1,
  "department": "Pictorium",
  "governor": {
    "name": "Moriana",
    "status": "active",
    "port": 7103,
    "task_kinds": ["image_generation"],
    "route_terms": [
      "картин",
      "image",
      "stable diffusion",
      "рисовал",
      "forge",
      "flux",
      "sdxl",
      "lora"
    ]
  },
  "backend": {
    "name": "Pictorium ForgeRuntime",
    "engine_package": "DemonsForge/forge_service/engines",
    "scope": "Pictorium-owned API, queue, storage, schemas, project runtime, and scripts around graphical engines",
    "default_url": "http://127.0.0.1:8110",
    "adapter_worker": "ForgeRelay",
    "adapter_port": 7010
  },
  "brigades": [
    {
      "name": "Image",
      "status": "active",
      "role": "still image generation, editing, inpaint, upscale, verification, and delivery",
      "path": "EyeOfTerror/Pictorium/Brigades/Image"
    },
    {
      "name": "Comics",
      "status": "planned",
      "role": "storyboards, multi-panel pages, lettering, continuity, and long-form visual projects",
      "path": "EyeOfTerror/Pictorium/Brigades/Comics"
    },
    {
      "name": "Video",
      "status": "planned",
      "role": "future video backends, GPU scheduling, clips, and image-to-video/text-to-video workflows",
      "path": "EyeOfTerror/Pictorium/Brigades/Video"
    }
  ],
  "workers": [
    {
      "name": "Promptwright",
      "role": "image prompt and job-spec planner",
      "source_modules": [
        "EyeOfTerror/Pictorium/Moriana/moriana_core/promptwright.py",
        "EyeOfTerror/Pictorium/Moriana/moriana_core/prompt_thinker.py",
        "EyeOfTerror/Pictorium/Moriana/moriana_core/project_planner.py",
        "EyeOfTerror/Pictorium/Moriana/moriana_core/character_profiles.py",
        "EyeOfTerror/Pictorium/Moriana/forge_runtime/schemas.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/Promptwright/worker.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/Promptwright/worker.json"
      ],
      "expected_artifacts": ["/work/pictorium/image_plan.json"]
    },
    {
      "name": "ModelQuartermaster",
      "role": "model, LoRA, embedding, and asset readiness inspector",
      "source_modules": [
        "EyeOfTerror/Pictorium/Moriana/moriana_core/asset_catalog.py",
        "EyeOfTerror/Pictorium/Moriana/moriana_core/asset_downloader.py",
        "DemonsForge/quality_assets/asset_profiles.json",
        "DemonsForge/quality_assets/character_profiles.json",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ModelQuartermaster/worker.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ModelQuartermaster/worker.json"
      ],
      "expected_artifacts": ["/work/pictorium/resource_report.json"]
    },
    {
      "name": "ForgeDispatcher",
      "role": "DemonsForge job submitter and monitor",
      "source_modules": [
        "EyeOfTerror/Pictorium/Moriana/forge_runtime/client.py",
        "EyeOfTerror/Pictorium/Moriana/forge_runtime/queue.py",
        "EyeOfTerror/Pictorium/Moriana/forge_runtime/server.py",
        "EyeOfTerror/Pictorium/Moriana/forge_runtime/projects.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ForgeDispatcher/worker.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ForgeDispatcher/worker.json"
      ],
      "expected_artifacts": ["/work/pictorium/forge_jobs.json"]
    },
    {
      "name": "ImageVerifier",
      "role": "generated artifact verifier and visual risk reporter",
      "source_modules": [
        "EyeOfTerror/Pictorium/Moriana/moriana_core/image_evaluator.py",
        "EyeOfTerror/Pictorium/Moriana/benches/quality_bench.py",
        "EyeOfTerror/Pictorium/Moriana/benches/long_forge_api.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ImageVerifier/worker.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ImageVerifier/worker.json"
      ],
      "expected_artifacts": ["/work/pictorium/image_verification.json"]
    },
    {
      "name": "ArtifactFinalis",
      "role": "final manifest and delivery packager",
      "source_modules": [
        "EyeOfTerror/Pictorium/Moriana/forge_runtime/storage.py",
        "EyeOfTerror/Pictorium/Moriana/moriana_core/forge_reports.py",
        "EyeOfTerror/Pictorium/Moriana/benches/project_bench.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ArtifactFinalis/worker.py",
        "EyeOfTerror/Pictorium/Brigades/Image/Workers/ArtifactFinalis/worker.json"
      ],
      "expected_artifacts": ["/work/pictorium/final_manifest.json"]
    }
  ],
  "activation_requirements": [
    "Moriana governor service exposes GET /health, GET /capabilities, POST /plan, and POST /prepare_run",
    "each brigade worker exposes the common Worker API",
    "Warmaster can prepare an image_generation run package without calling DemonsForge directly",
    "DemonsForge job failures are surfaced as structured blockers",
    "asset downloads require explicit approval and safe source validation",
    "generated image artifacts appear in Warmaster artifact endpoints"
  ]
}
