{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EyeOfTerror Task Contract",
  "type": "object",
  "required": ["version", "task_id", "kind", "goal", "assigned_governor", "completion_criteria"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["chat", "research", "image_generation", "code", "general"]
    },
    "goal": { "type": "string", "minLength": 1 },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assigned_governor": { "type": "string", "minLength": 1 },
    "required_artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^/work/" }
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "quality_gates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "worker_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "worker", "purpose"],
        "additionalProperties": false,
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "worker": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "expected_artifacts": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^/work/" }
          }
        }
      }
    }
  }
}
