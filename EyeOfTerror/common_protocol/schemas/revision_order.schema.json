{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "revision_order",
  "type": "object",
  "required": ["type", "protocol_version", "mission_id", "created_at", "from", "to", "reason", "order", "required_steps"],
  "properties": {
    "type": { "const": "revision_order" },
    "protocol_version": { "const": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "from": { "const": "Warmaster" },
    "to": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "order": { "type": "string", "minLength": 1 },
    "required_steps": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
