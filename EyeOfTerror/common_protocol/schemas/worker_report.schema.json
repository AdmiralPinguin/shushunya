{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "worker_report",
  "type": "object",
  "required": ["type", "protocol_version", "mission_id", "created_at", "step_id", "worker", "status", "summary", "artifacts", "problems", "next_recommended_action"],
  "properties": {
    "type": { "const": "worker_report" },
    "protocol_version": { "const": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "step_id": { "type": "string", "minLength": 1 },
    "worker": { "type": "string", "minLength": 1 },
    "status": { "enum": ["done", "blocked", "needs_revision", "failed"] },
    "summary": { "type": "string", "minLength": 1 },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "problems": { "type": "array", "items": { "type": "string" } },
    "next_recommended_action": { "type": "string" }
  },
  "additionalProperties": true
}
