    "status": { "type": "string", "minLength": 1 },
    "accepted_by": { "type": "string", "minLength": 1 },
    "answer": { "type": "string", "minLength": 1 },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
