{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "governor_plan",
  "type": "object",
  "required": ["type", "protocol_version", "mission_id", "created_at", "governor", "understanding", "work_plan", "quality_gates", "expected_deliverables"],
  "properties": {
    "type": { "const": "governor_plan" },
    "protocol_version": { "const": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "governor": { "type": "string", "minLength": 1 },
    "understanding": { "type": "string", "minLength": 1 },
    "work_plan": { "type": "array", "items": { "type": "object" } },
    "quality_gates": { "type": "array", "items": { "type": "string" } },
    "expected_deliverables": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
