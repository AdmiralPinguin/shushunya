{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "governor_report",
  "type": "object",
  "required": ["type", "protocol_version", "mission_id", "created_at", "governor", "status", "summary", "deliverables", "quality_review", "revision_plan", "user_facing_answer"],
  "properties": {
    "type": { "const": "governor_report" },
    "protocol_version": { "const": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "governor": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ready", "needs_revision", "blocked", "failed"] },
    "summary": { "type": "string", "minLength": 1 },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "quality_review": { "type": "object" },
    "revision_plan": { "type": "object" },
    "user_facing_answer": { "type": "string" }
  },
  "additionalProperties": true
}
