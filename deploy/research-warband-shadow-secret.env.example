# Copy to /media/shushunya/SHUSHUNYA/shushunya/.secrets/research-warband-shadow.env
# with mode 0600. Generate a new high-entropy value; never commit the real token.
RESEARCH_WARBAND_BEARER_TOKEN=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
# Optional. The deployment guard records only its SHA-256 digest, never the key.
SHUSHUNYA_SEARCH_BRAVE_API_KEY=
